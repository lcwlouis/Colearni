# App
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
APP_DATABASE_URL=postgresql+psycopg://colearni:colearni@localhost:5432/colearni

# Embeddings (dimension depends on model; keep configurable)
APP_EMBEDDING_DIM=1536
APP_EMBEDDING_PROVIDER=openai
APP_EMBEDDING_MODEL=text-embedding-3-small
APP_EMBEDDING_BATCH_SIZE=32
APP_INGEST_POPULATE_EMBEDDINGS=false
APP_INGEST_BUILD_GRAPH=false
APP_EMBEDDING_BACKFILL_MAX_CHUNKS=500
APP_EMBEDDING_TIMEOUT_SECONDS=15
APP_RETRIEVAL_MAX_TOP_K=20
APP_OPENAI_API_KEY=
# LiteLLM embedding proxy config (used when APP_EMBEDDING_PROVIDER=litellm)
APP_LITELLM_MODEL=text-embedding-3-small
APP_LITELLM_BASE_URL=http://localhost:4000/v1
APP_LITELLM_API_KEY=
APP_GRAPH_LLM_PROVIDER=openai
APP_GRAPH_LLM_MODEL=gpt-4.1-mini
APP_GRAPH_LLM_TIMEOUT_SECONDS=30

# Mode defaults
APP_DEFAULT_GROUNDING_MODE=hybrid  # hybrid | strict

# Budgets (chat + resolver + gardener)
CHAT_MAX_TOOL_CALLS=6
RESOLVER_LEXICAL_TOP_K=5
RESOLVER_VECTOR_TOP_K=10
RESOLVER_CANDIDATE_CAP=10
RESOLVER_LEXICAL_SIMILARITY_THRESHOLD=0.85
RESOLVER_LEXICAL_MARGIN_THRESHOLD=0.10
RESOLVER_VECTOR_SIMILARITY_THRESHOLD=0.92
RESOLVER_VECTOR_MARGIN_THRESHOLD=0.06
RESOLVER_LLM_CONFIDENCE_FLOOR=0.65
RESOLVER_MAX_LLM_CALLS_PER_CHUNK=3
RESOLVER_MAX_LLM_CALLS_PER_DOCUMENT=50
RESOLVER_CONCEPT_DESCRIPTION_MAX_CHARS=500
RESOLVER_EDGE_DESCRIPTION_MAX_CHARS=300
RESOLVER_EDGE_WEIGHT_CAP=10
GARDENER_MAX_LLM_CALLS_PER_RUN=30
GARDENER_MAX_CLUSTERS_PER_RUN=50
GARDENER_MAX_DIRTY_NODES_PER_RUN=200
GARDENER_RECENT_WINDOW_DAYS=7
