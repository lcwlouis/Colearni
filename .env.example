# ── App / Server ──────────────────────────────────────────────────────
APP_ENV=dev                                  # dev | staging | prod
APP_LOG_LEVEL=INFO                           # DEBUG, INFO, WARNING, ERROR
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4                                # Uvicorn workers (≥ 1)

# ── CORS ──────────────────────────────────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]                    # Comma-separated origins (empty = none)
APP_CORS_ALLOWED_METHODS=["*"]                   # Comma-separated HTTP methods

# ── Database ──────────────────────────────────────────────────────────
APP_DATABASE_URL=postgresql+psycopg://colearni:colearni@localhost:5432/colearni

# ── API Keys ──────────────────────────────────────────────────────────
# Uncomment and set when using openai provider for embeddings or graph LLM.
APP_OPENAI_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────
APP_EMBEDDING_PROVIDER=openai                  # openai | litellm | mock
APP_EMBEDDING_MODEL=text-embedding-3-small
APP_EMBEDDING_DIM=1536                       # Must match model output dimension
APP_EMBEDDING_BATCH_SIZE=32                  # Chunks per embedding API call (≥ 1)
APP_EMBEDDING_TIMEOUT_SECONDS=45             # Per-request timeout (> 0)
APP_EMBEDDING_BACKFILL_MAX_CHUNKS=500        # Max chunks per backfill run (≥ 1)
APP_RETRIEVAL_MAX_TOP_K=20                   # Upper bound for top-k retrieval (≥ 1)

# ── LiteLLM Proxy (used when APP_EMBEDDING_PROVIDER=litellm) ─────────
APP_LITELLM_BASE_URL=http://localhost:4000/v1
APP_LITELLM_MODEL=                           # Model name for litellm proxy
APP_LITELLM_API_KEY=                         # API key for litellm proxy

# ── Ingestion flags ──────────────────────────────────────────────────
APP_INGEST_POPULATE_EMBEDDINGS=true         # Generate embeddings during ingest
APP_INGEST_BUILD_GRAPH=true                 # Build knowledge graph during ingest

# ── Ingestion / Chunking ──
APP_INGEST_CHUNK_UNIT=words                 # "words" or "chars" (default: words)
APP_INGEST_VECTOR_CHUNK_SIZE=250            # Target words per vector chunk (default: 250)
APP_INGEST_VECTOR_CHUNK_OVERLAP=40          # Word overlap between chunks (default: 40)
APP_INGEST_GRAPH_CHUNK_SIZE=20000           # Target words per graph LLM window (default: 20000)

# ── Graph LLM ────────────────────────────────────────────────────────
APP_GRAPH_LLM_PROVIDER=openai                  # openai | litellm | mock
APP_GRAPH_LLM_MODEL=gpt-4.1-mini
APP_GRAPH_LLM_TIMEOUT_SECONDS=30             # Per-request timeout (> 0)
APP_GRAPH_LLM_JSON_TEMPERATURE=0             # Temperature for JSON extraction (0–2)
APP_GRAPH_LLM_TUTOR_TEMPERATURE=0            # Temperature for tutor responses (0–2)

# ── Retrieval / Grounding ────────────────────────────────────────────
APP_DEFAULT_GROUNDING_MODE=hybrid            # hybrid | strict

# ── Resolver budgets ─────────────────────────────────────────────────
APP_RESOLVER_LEXICAL_TOP_K=5
APP_RESOLVER_VECTOR_TOP_K=10
APP_RESOLVER_CANDIDATE_CAP=10
APP_RESOLVER_LEXICAL_SIMILARITY_THRESHOLD=0.85
APP_RESOLVER_LEXICAL_MARGIN_THRESHOLD=0.10
APP_RESOLVER_VECTOR_SIMILARITY_THRESHOLD=0.92
APP_RESOLVER_VECTOR_MARGIN_THRESHOLD=0.06
APP_RESOLVER_LLM_CONFIDENCE_FLOOR=0.65
APP_RESOLVER_MAX_LLM_CALLS_PER_CHUNK=3
APP_RESOLVER_MAX_LLM_CALLS_PER_DOCUMENT=50
APP_RESOLVER_CONCEPT_DESCRIPTION_MAX_CHARS=500
APP_RESOLVER_EDGE_DESCRIPTION_MAX_CHARS=300
APP_RESOLVER_EDGE_WEIGHT_CAP=10.0
# How many concepts to disambiguate per LLM call (1=no batching, 5=default, up to 50 for capable models)
APP_RESOLVER_DISAMBIGUATE_BATCH_SIZE=5
# Max estimated tokens per batch disambiguation call (splits large batches)
APP_DISAMBIGUATE_MAX_TOKENS_PER_BATCH=30000

# ── Gardener budgets ─────────────────────────────────────────────────
APP_GARDENER_MAX_LLM_CALLS_PER_RUN=30
APP_GARDENER_MAX_CLUSTERS_PER_RUN=50
APP_GARDENER_MAX_DIRTY_NODES_PER_RUN=200
APP_GARDENER_RECENT_WINDOW_DAYS=7
APP_GARDENER_FULL_SCAN_MAX_SEEDS=10000
APP_GARDENER_FULL_SCAN_MAX_CLUSTERS=500
APP_GARDENER_FULL_SCAN_MAX_LLM_CALLS=200

# ── Gardener full-scan candidate search ──────────────────────────────
APP_GARDENER_FULL_SCAN_LEXICAL_TOP_K=20
APP_GARDENER_FULL_SCAN_VECTOR_TOP_K=30
APP_GARDENER_FULL_SCAN_CANDIDATE_CAP=30

# Max candidates per concept in gardener batch (reduces prompt size)
APP_GARDENER_MAX_CANDIDATES_PER_ITEM=10

# ── Observability (opt-in; see docs/OBSERVABILITY.md) ────────────────
APP_OBSERVABILITY_ENABLED=true
APP_OBSERVABILITY_OTLP_ENDPOINT=http://localhost:6006             # e.g. http://localhost:6006
APP_OBSERVABILITY_SERVICE_NAME=colearni-backend
APP_OBSERVABILITY_RECORD_CONTENT=true

# ── Chat ──────────────────────────────────────────────────────────────
APP_CHAT_STREAMING_ENABLED=true             # SSE streaming for chat responses

# ── Auth ──────────────────────────────────────────────────────────────
APP_AUTH_MAGIC_LINK_TTL_MINUTES=30
APP_AUTH_SESSION_TTL_DAYS=14

# ── Readiness / half-life ────────────────────────────────────────────
APP_READINESS_CADENCE_HOURS=24
APP_READINESS_HALF_LIFE_DAYS=7.0

# ── Research agent ────────────────────────────────────────────────────
APP_RESEARCH_MAX_SOURCES_PER_WORKSPACE=20
APP_RESEARCH_MAX_CANDIDATES_PER_RUN=50

# ── Persona / social-intent ──────────────────────────────────────────
APP_TUTOR_PERSONA=colearni
APP_SOCIAL_INTENT_ENABLED=true

# ── Reasoning toggles (per-task; true = request extended thinking) ────
APP_LLM_REASONING_CHAT=true
APP_LLM_REASONING_QUIZ_GRADING=false
APP_LLM_REASONING_GRAPH_GENERATION=false
APP_LLM_REASONING_QUIZ_GENERATION=false

# ── Reasoning effort (none/low/medium/high; blank = provider default) ─
# Only applied when the corresponding reasoning toggle is true and the model supports it.
# "none" disables explicit reasoning params even when the toggle is true.
APP_LLM_REASONING_EFFORT_CHAT=low
APP_LLM_REASONING_EFFORT_QUIZ_GRADING=low
APP_LLM_REASONING_EFFORT_GRAPH_GENERATION=low
APP_LLM_REASONING_EFFORT_QUIZ_GENERATION=low

# ── Reasoning summary (ephemeral, never persisted in chat history) ────
APP_REASONING_SUMMARY_ENABLED=true

# ── Feature flags ────────────────────────────────────────────────────
APP_SOCRATIC_MODE_DEFAULT=true              # Default state of Socratic toggle in UI
APP_INCLUDE_DEV_STATS=true                  # Include generation_trace in chat responses

# ── Docker Compose (not read by the app; for docker-compose.yml) ─────
POSTGRES_DB=colearni
POSTGRES_USER=colearni
POSTGRES_PASSWORD=colearni
