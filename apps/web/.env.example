# ── Backend proxy ─────────────────────
# Target backend API origin used by the Next.js /api proxy rewrite.
BACKEND_BASE_URL=http://127.0.0.1:8000

# ── API client ────────────────────────
# Browser API base URL used by the typed client.
# Keep this as /api in local dev to avoid CORS issues.
NEXT_PUBLIC_API_BASE_URL=/api

# Direct backend URL for SSE streaming (bypasses Next.js rewrite proxy).
# Set this to the backend origin to avoid SSE buffering.
NEXT_PUBLIC_STREAM_BASE_URL=http://127.0.0.1:8000

# ── Feature flags ────────────────────
# Chat streaming response (controls whether to use streaming endpoints and UI)
NEXT_PUBLIC_CHAT_STREAMING_ENABLED=true

# Reasoning summary UI (ephemeral, live-turn only)
NEXT_PUBLIC_REASONING_SUMMARY_ENABLED=true